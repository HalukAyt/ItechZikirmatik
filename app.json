{
  "expo": {
    "name": "ItechZikirmatik",
    "slug": "ItechZikirmatik",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/Itech.png",
    "scheme": "itechzikirmatik",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halukayt.ItechZikirmatik",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "permissions": ["VIBRATE", "INTERNET"],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.halukayt.ItechZikirmatik"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Itech.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7283360706215445~9860520323",
          "iosAppId": "ca-app-pub-7283360706215445~4201097591"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8cf37bba-5c39-469f-829e-24add7d37dc9"
      }
    }
  }
}
